# SPL Forge Environment Configuration
# Copy this file to .env.local and update values for your environment
# DO NOT COMMIT .env.local to Git (add to .gitignore)

# === Splunk Connectivity ===

# Splunk host URL (with protocol and port)
SPLUNK_HOST=https://localhost:8089

# Splunk admin username
SPLUNK_USERNAME=admin

# Splunk admin password
SPLUNK_PASSWORD=SplunkDemo123!

# Splunk index to use for queries
SPLUNK_INDEX=main

# Verify SSL certificate (set to 'false' for self-signed local Splunk certs)
SPLUNK_VERIFY_SSL=false

# === SPL Forge Configuration ===

# Environment (development, staging, production)
SPL_FORGE_ENV=development

# Splunk connectivity mode: 'rest', 'mcp', or 'mock'
SPL_FORGE_SPLUNK_MODE=mock

# Splunk source: 'self_hosted_trial', 'local', 'cloud', or 'mock'
SPL_FORGE_SPLUNK_SOURCE=self_hosted_trial

# Day 4 REST execution endpoint and limits
SPL_FORGE_SPLUNK_URL=https://localhost:8089
SPL_FORGE_SPLUNK_ALLOW_SELF_SIGNED=true
SPL_FORGE_SPLUNK_SEARCH_LIMIT=10

# Day 5 repair loop policy. true auto-reruns repaired SPL; false stops after repair proposal.
SPL_FORGE_REPAIR_AUTO_RUN=true

# Optional dashboard publish target for npm run publish:dashboard
SPL_FORGE_SPLUNK_APP=search
SPL_FORGE_SPLUNK_OWNER=nobody
SPL_FORGE_DASHBOARD_VIEW=failed_login_dashboard
# SPLUNK_WEB_URL=http://localhost:8000

# Splunk MCP Server mode
# Use encrypted MCP token generated by Splunk MCP Server app.
# Do not reuse direct Splunk REST tokens here.
# SPL_FORGE_SPLUNK_MCP_ENDPOINT=https://your-splunk-mcp-endpoint
# SPL_FORGE_SPLUNK_MCP_TOKEN=your-encrypted-mcp-token
# SPL_FORGE_SPLUNK_MCP_ALLOW_SELF_SIGNED=false

# Token auth is preferred for non-local Splunk environments
# SPL_FORGE_SPLUNK_TOKEN=your-splunk-token

# Basic auth fallback for local development only
# SPL_FORGE_SPLUNK_USERNAME=admin
# SPL_FORGE_SPLUNK_PASSWORD=your-local-password

# === Optional: LLM Configuration ===
# (Required when implementing AI/LLM features)

# LLM provider: 'groq', 'openai', 'anthropic', 'local', or 'mock'
SPL_FORGE_LLM_PROVIDER=mock

# Groq API key
# GROQ_API_KEY=your_groq_key_here

# Groq model name
GROQ_MODEL=llama-3.1-8b-instant

# LLM API key (keep secure, use environment variable)
# SPL_FORGE_LLM_API_KEY=your-api-key-here

# LLM model name
SPL_FORGE_LLM_MODEL=mock-spl-forge-v1

# === Optional: MCP Configuration ===
# (Required when implementing MCP mode)

# MCP server URL
# SPL_FORGE_MCP_URL=http://localhost:3001

# MCP authentication token
# SPL_FORGE_MCP_TOKEN=your-mcp-token

# === Optional: Logging ===

# Log level: 'debug', 'info', 'warn', 'error'
SPL_FORGE_LOG_LEVEL=debug

# Log file path (optional)
# SPL_FORGE_LOG_FILE=./logs/spl-forge.log
